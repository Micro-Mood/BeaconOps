# Storage
DATA_DIR=./data

# Seed admin user
# Generate a hash with:
# python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=PASTE_BCRYPT_HASH_HERE

# App environment
ENVIRONMENT=production

# JWT session secret
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_VALUE

# MQTT bridge connection
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=beacon-bridge
MQTT_PASSWORD=CHANGE_ME

# Device auth webhook
HMAC_MAX_SKEW_S=300
NONCE_TTL_S=600
AUTH_WEBHOOK_TOKEN=

# Downlink retry policy
DOWNLINK_MAX_ATTEMPTS=10
DOWNLINK_BACKOFF_BASE_S=2
DOWNLINK_BACKOFF_MAX_S=300

# Optional device health history
HEALTH_HISTORY_ENABLED=0